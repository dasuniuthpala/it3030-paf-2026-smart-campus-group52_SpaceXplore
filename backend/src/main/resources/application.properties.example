# -------------------------------------------------------------------------
# SpaceXplore - Application Configuration Template
# -------------------------------------------------------------------------
# Copy this file to application.properties and fill in your real credentials.
# DO NOT commit the application.properties file with real secrets!

spring.application.name=demo

# Database Configuration (PostgreSQL/Neon)
spring.datasource.url=jdbc:postgresql://your-host:5432/your-db?sslmode=require
spring.datasource.username=your-username
spring.datasource.password=your-password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA/Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# Server
server.port=8086

# CORS
app.cors.allowed-origins=http://localhost:3000,http://127.0.0.1:3000

# Google OAuth2 (Get these from Google Cloud Console)
spring.security.oauth2.client.registration.google.client-id=YOUR_CLIENT_ID.apps.googleusercontent.com
spring.security.oauth2.client.registration.google.client-secret=YOUR_CLIENT_SECRET
spring.security.oauth2.client.registration.google.scope=profile, email

# Super Admin Role Bootstrap
# The email defined here will automatically be promoted to SUPER_ADMIN on first login
app.admin.email=your-admin-email@gmail.com
app.admin.name=Super Admin
